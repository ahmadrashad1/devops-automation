# Copy to ".env" in the repo root. Docker Compose loads ".env" automatically.

# --- Recommended: Groq (free dev tier, high limits) — https://console.groq.com/keys ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- Google Gemini (free tier has strict quotas; add Groq above to avoid 429) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional: force one provider: groq | gemini | openai
# AI_PROVIDER=groq

# --- OpenAI (optional, paid) ---
# OPENAI_API_KEY=

# If host port 3010 is busy:
# API_HOST_PORT=3012

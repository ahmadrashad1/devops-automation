{
  "name": "devops-automation-saas",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev:api": "pnpm --filter api dev",
    "dev:dashboard": "pnpm --filter dashboard dev",
    "dev:worker": "pnpm --filter worker dev",
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:dashboard\" \"pnpm dev:worker\"",
    "docker:infra": "docker compose up -d",
    "docker:up": "docker compose --profile full up --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}


{
  "name": "devops-automation-saas",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev:api": "pnpm --filter api dev",
    "dev:dashboard": "pnpm --filter dashboard dev",
    "dev:worker": "pnpm --filter worker dev",
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:dashboard\" \"pnpm dev:worker\"",
    "docker:infra": "docker compose up -d",
    "docker:up": "docker compose --profile full up --build",
    "docker:down": "docker compose down",
    "tf:init": "terraform -chdir=infra/terraform init",
    "tf:plan": "terraform -chdir=infra/terraform plan",
    "tf:apply": "terraform -chdir=infra/terraform apply",
    "tf:destroy": "terraform -chdir=infra/terraform destroy",
    "tf:aws:init": "terraform -chdir=infra/terraform/aws init",
    "tf:aws:plan": "terraform -chdir=infra/terraform/aws plan",
    "tf:aws:apply": "terraform -chdir=infra/terraform/aws apply",
    "tf:aws:destroy": "terraform -chdir=infra/terraform/aws destroy"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}

